{
  "manifest_version": 3,
  "name": "Shiba-Kun Study Pro",
  "version": "1.8",
  "permissions": ["sidePanel", "storage", "tabs", "scripting"],
  "action": {
    "default_icon": "icon.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}